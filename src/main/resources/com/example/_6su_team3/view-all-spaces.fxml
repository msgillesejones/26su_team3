<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.team3.controller.ViewAllSpacesController">

    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <TextField fx:id="nameSearchField" promptText="Search by name" />
            <TextField fx:id="capacityFilterField" promptText="Minimum capacity" />
            <Button text="Apply Filter" onAction="#applyCapacityFilter" />

            <!-- ⭐⭐ NEW BUTTON ⭐⭐ -->
            <Button text="View Day Availability" onAction="#openDayAvailability" />

        </HBox>
    </top>

    <center>
        <TableView fx:id="table">
            <columns>
                <TableColumn fx:id="nameColumn" text="Name" />
                <TableColumn fx:id="capacityColumn" text="Capacity" />
                <TableColumn fx:id="featuresColumn" text="Features" />
            </columns>
        </TableView>
    </center>

</BorderPane>


