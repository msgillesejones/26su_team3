<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.team3.controller.MyReservationsController">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <TextField fx:id="userField" promptText="Enter user name"/>

    <Button text="View My Reservations"
            onAction="#loadReservations"/>
    <Button text="Cancel Selected Reservation"
            onAction="#cancelReservation"/>
    <TextField fx:id="newStartTimeField"
               promptText="New start time (HH:mm)"/>

    <TextField fx:id="newEndTimeField"
               promptText="New end time (HH:mm)"/>
    <Button text="Modify Selected Reservation"
            onAction="#modifyReservation"/>

    <Label fx:id="messageLabel"/>

    <TableView fx:id="reservationTable">
        <columns>
            <TableColumn fx:id="spaceColumn" text="Space"/>
            <TableColumn fx:id="dateColumn" text="Date"/>
            <TableColumn fx:id="timeColumn" text="Time"/>
        </columns>
    </TableView>

</VBox>